---
layout: base.njk
---
    <section class="page-header" style="background: linear-gradient(rgba(10, 122, 74, 0.8), rgba(6, 95, 58, 0.9)), url('https://images.unsplash.com/photo-1573164713988-8665fc963095?auto=format&fit=crop&w=1600&q=80') center/cover; padding: 6rem 0; text-align: center; color: white;">
        <div class="container">
            <h1 style="font-size: 2.8rem; margin-bottom: 1rem;">{{ title }}</h1>
            <div style="display: flex; gap: 20px; justify-content: center; flex-wrap: wrap; font-size: 1.1rem; opacity: 0.9;">
                <span><i class="fas fa-building"></i> Khối Văn Phòng</span>
                <span><i class="fas fa-map-marker-alt"></i> Hà Nội</span>
                <span><i class="fas fa-clock"></i> Toàn thời gian</span>
            </div>
        </div>
    </section>
    <section style="padding: 5rem 0; background: #fff;">
        <div class="container" style="max-width: 800px;">
            <div class="jd-content" style="background: #fff; padding: 3rem; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); border: 1px solid #eee; line-height: 1.8; font-size: 1.05rem;">
                {{ content | safe }}
                <div style="text-align: center; margin-top: 4rem; padding-top: 2rem; border-top: 1px solid #eee;">
                    <p style="font-size: 1.2rem; color: var(--text-muted); margin-bottom: 1.5rem;">Sẵn sàng để trở thành một phần của Green Box?</p>
                    <a href="mailto:hr@greenbox.vn?subject=Ứng Tuyển Vị Trí {{ title }}" class="btn-accent" style="display: inline-block; padding: 15px 50px; font-size: 1.3rem; border-radius: 50px;">ỨNG TUYỂN NGAY</a>
                </div>
            </div>
        </div>
    </section>
