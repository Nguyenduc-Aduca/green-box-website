---
layout: base.njk
---
    <!-- Hero Section -->
    <section class="page-header" style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.8)), url('{{ hero_bg | default("https://images.unsplash.com/photo-1628151015968-3a4429e9ef04?auto=format&fit=crop&w=1600&q=80") }}') center/cover; padding: 6rem 0; text-align: center; color: white;">
        <div class="container">
            <h1 style="font-size: 3rem; margin-bottom: 1rem; color: #fff;">{{ title }}</h1>
            <p style="font-size: 1.2rem; max-width: 800px; margin: 0 auto; opacity: 0.9;">{{ subtitle }}</p>
        </div>
    </section>

    <!-- Main Content Section -->
    <section class="content-section design-section" style="padding: 5rem 0; background: #fff;">
        <div class="container">
            {% for section in sections %}
            <div style="display: flex; flex-wrap: wrap; gap: 4rem; margin-bottom: 4rem; align-items: center; {{ 'flex-direction: row-reverse;' if loop.index0 % 2 != 0 else '' }}">
                <div style="flex: 1; min-width: 300px;">
                    <h2 style="color: var(--primary); font-size: 2.2rem; margin-bottom: 1.5rem;">{{ section.title }}</h2>
                    <div class="markdown-content" style="font-size: 1.1rem; line-height: 1.8; color: var(--text-muted); margin-bottom: 1.5rem;">
                        {{ section.desc | safe }}
                    </div>
                </div>
                <div style="flex: 1; min-width: 300px;">
                    <img loading="lazy" src="{{ section.image }}" style="width: 100%; border-radius: 12px; box-shadow: 0 20px 40px rgba(0,0,0,0.1);">
                </div>
            </div>
            {% endfor %}
        </div>
    </section>

    <!-- Workflow Section -->
    <section style="padding: 5rem 0; background: var(--surface);">
        <div class="container" style="text-align: center;">
            <h2 style="color: var(--primary); font-size: 2.5rem; margin-bottom: 3rem;">QUY TRÌNH SÁNG TẠO</h2>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem;">
                {% for step in workflows %}
                <div style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
                    <div style="width: 60px; height: 60px; background: var(--accent); color: #000; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; font-weight: bold; margin: 0 auto 1rem;">{{ loop.index }}</div>
                    <h3 style="margin-bottom: 1rem;">{{ step.title }}</h3>
                    <p style="color: var(--text-muted); font-size: 0.95rem;">{{ step.desc }}</p>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- CTA Form Section -->
    <section style="padding: 5rem 0; background: var(--primary);">
        <div class="container" style="text-align: center;">
            <h2 style="color: white; font-size: 2.5rem; margin-bottom: 1rem;">KHỞI TẠO DỰ ÁN THIẾT KẾ CỦA BẠN</h2>
            <p style="color: white; opacity: 0.9; font-size: 1.2rem; margin-bottom: 3rem; max-width: 600px; margin-left: auto; margin-right: auto;">Để lại thông tin, các chuyên gia thiết kế của Green Box sẽ liên hệ tư vấn giải pháp tối ưu nhất trong vòng 30 phút.</p>
            
            <form style="max-width: 600px; margin: 0 auto; background: white; padding: 3rem; border-radius: 12px; text-align: left; box-shadow: 0 20px 40px rgba(0,0,0,0.2);">
                <div style="margin-bottom: 1.5rem;">
                    <label style="display: block; font-weight: 600; margin-bottom: 0.5rem;">Họ tên / Tên công ty *</label>
                    <input type="text" placeholder="Nhập tên của bạn" style="width: 100%; padding: 12px; border: 1px solid var(--border); border-radius: 6px; font-size: 1rem;">
                </div>
                <div style="margin-bottom: 1.5rem;">
                    <label style="display: block; font-weight: 600; margin-bottom: 0.5rem;">Số điện thoại (Zalo) *</label>
                    <input type="tel" placeholder="Nhập số điện thoại" style="width: 100%; padding: 12px; border: 1px solid var(--border); border-radius: 6px; font-size: 1rem;">
                </div>
                <div style="margin-bottom: 2rem;">
                    <label style="display: block; font-weight: 600; margin-bottom: 0.5rem;">Yêu cầu thiết kế chi tiết</label>
                    <textarea rows="4" placeholder="Mô tả ngắn gọn sản phẩm bạn cần thiết kế..." style="width: 100%; padding: 12px; border: 1px solid var(--border); border-radius: 6px; font-size: 1rem; resize: vertical;"></textarea>
                </div>
                <button type="button" class="btn-accent" style="width: 100%; font-size: 1.1rem; border: none; cursor: pointer;">GỬI YÊU CẦU NGAY</button>
            </form>
        </div>
    </section>
