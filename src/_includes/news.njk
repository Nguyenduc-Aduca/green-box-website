---
layout: base.njk
---
    <!-- Page Header -->
    <section class="page-header">
        <div class="container">
            <h1>Tin Tức & Sự Kiện</h1>
            <p>Cập nhật những xu hướng và kiến thức mới nhất</p>
        </div>
    </section>

    <!-- Main Content -->
    <section class="content-section">
        <div class="container content-container">
            <div class="content-block">
                <h2 style="font-size: 2.5rem; color: var(--primary-dark); line-height: 1.3; margin-bottom: 1rem; border: none; padding: 0;">{{ title }}</h2>
                <p style="color: var(--text-muted); font-size: 1rem; margin-bottom: 2rem; border-bottom: 1px solid var(--border); padding-bottom: 1rem;"><i class="fas fa-calendar-alt"></i> Ngày đăng: {{ date.toLocaleDateString() if date else '' }} | Bởi: {{ author }}</p>
                
                {{ content | safe }}
                
                <div style="margin-top: 4rem; text-align: center; border-top: 1px solid var(--border); padding-top: 2rem;">
                    <a href="/news.html" class="btn btn-primary"><i class="fas fa-arrow-left"></i> Quay lại danh sách tin tức</a>
                </div>
            </div>
        </div>
    </section>
